# =============================================================================
# WarehouseIQ - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=warehouseiq
POSTGRES_USER=warehouseiq
POSTGRES_PASSWORD=warehouseiq_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://warehouseiq:warehouseiq_secret@localhost:5432/warehouseiq

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:redis_secret@localhost:6379/0

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://:redis_secret@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@localhost:6379/2

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# -----------------------------------------------------------------------------
# JWT Token Lifetimes
# -----------------------------------------------------------------------------
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# Email (for notifications)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Shipping Carrier API Keys
# -----------------------------------------------------------------------------
UPS_API_KEY=
UPS_API_SECRET=
FEDEX_API_KEY=
FEDEX_API_SECRET=
USPS_USERNAME=
DHL_API_KEY=
DHL_API_SECRET=

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_PORT=80

# -----------------------------------------------------------------------------
# Stock Alert Thresholds
# -----------------------------------------------------------------------------
DEFAULT_LOW_STOCK_THRESHOLD=10
DEFAULT_OVERSTOCK_THRESHOLD=1000
STOCK_ALERT_CHECK_INTERVAL_MINUTES=15
